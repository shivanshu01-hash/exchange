# ============================================
# Cricket Trading Platform - Environment Variables
# ============================================
# Security Levels:
#   [PUBLIC]    - Can be exposed to client-side
#   [INTERNAL]  - Server-side only, not sensitive
#   [SECRET]    - Sensitive data (API keys, passwords)
#   [CRITICAL]  - Highly sensitive (encryption keys, JWT secrets)
# ============================================

# ==================== CORE SETTINGS ====================
# [PUBLIC] Application environment (development, test, production)
NODE_ENV=development

# [PUBLIC] API server port (Railway will auto-assign PORT)
PORT=4000
API_PORT=4000

# [PUBLIC] Web application origin (for CORS)
WEB_ORIGIN=http://localhost:3000

# ==================== DATABASE CONNECTIONS ====================
# [SECRET] MongoDB connection string
MONGODB_URI=mongodb://localhost:27017/odds_exchange

# [SECRET] Redis connection URL
REDIS_URL=redis://localhost:6379

# ==================== SECURITY CRITICAL ====================
# [CRITICAL] Secret key for signing JWT tokens (min 24 chars)
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace-with-64-byte-secure-random-hex-string

# [CRITICAL] Encryption key for sensitive data (optional, 32 bytes hex)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=

# ==================== EXTERNAL API KEYS ====================
# [SECRET] RapidAPI key for cricket data
RAPIDAPI_KEY=put-rapidapi-key-here

# [INTERNAL] RapidAPI cricket host
RAPIDAPI_CRICBUZZ_HOST=cricbuzz-cricket.p.rapidapi.com

# [SECRET] Betfair application key
BETFAIR_APP_KEY=put-app-key-here

# [SECRET] Betfair session token
BETFAIR_SESSION_TOKEN=put-session-token-here

# ==================== BUSINESS CONFIGURATION ====================
# [INTERNAL] Commission in basis points (1% = 100 bps)
COMMISSION_BPS=200

# [INTERNAL] Maximum exposure per user (in currency units)
MAX_USER_EXPOSURE=100000

# [INTERNAL] Maximum exposure per market (in currency units)
MAX_MARKET_EXPOSURE=1000000

# ==================== FRONTEND CONFIGURATION (NEXT_PUBLIC_*) ====================
# [PUBLIC] API URL for frontend (Railway will provide RAILWAY_STATIC_URL for web, RAILWAY_PUBLIC_DOMAIN for API)
NEXT_PUBLIC_API_URL=http://localhost:4000

# [PUBLIC] WebSocket URL (same as API URL for socket.io)
NEXT_PUBLIC_WS_URL=http://localhost:4000

# [PUBLIC] API timeout in milliseconds
NEXT_PUBLIC_API_TIMEOUT=10000

# [PUBLIC] API retry attempts
NEXT_PUBLIC_API_RETRY_ATTEMPTS=3

# [PUBLIC] API retry delay in milliseconds
NEXT_PUBLIC_API_RETRY_DELAY=1000

# [PUBLIC] WebSocket reconnect interval in milliseconds
NEXT_PUBLIC_WS_RECONNECT_INTERVAL=5000

# [PUBLIC] WebSocket max reconnect attempts
NEXT_PUBLIC_WS_MAX_RECONNECT_ATTEMPTS=10

# [PUBLIC] WebSocket ping interval in milliseconds
NEXT_PUBLIC_WS_PING_INTERVAL=30000

# [PUBLIC] Cache TTL in milliseconds
NEXT_PUBLIC_CACHE_TTL=300000

# [PUBLIC] Cache max items
NEXT_PUBLIC_CACHE_MAX_ITEMS=100

# [PUBLIC] Cache stale-while-revalidate in milliseconds
NEXT_PUBLIC_CACHE_SWR=60000

# [PUBLIC] Minimum stake amount
NEXT_PUBLIC_MIN_STAKE=1

# [PUBLIC] Maximum stake amount
NEXT_PUBLIC_MAX_STAKE=10000

# [PUBLIC] Default stake amount
NEXT_PUBLIC_DEFAULT_STAKE=10

# [PUBLIC] Minimum odds
NEXT_PUBLIC_MIN_ODDS=1.01

# [PUBLIC] Maximum odds
NEXT_PUBLIC_MAX_ODDS=1000

# [PUBLIC] Commission rate (0.05 = 5%)
NEXT_PUBLIC_COMMISSION_RATE=0.05

# [PUBLIC] Theme (light, dark, system)
NEXT_PUBLIC_THEME=light

# [PUBLIC] Odds format (decimal, fractional, american)
NEXT_PUBLIC_ODDS_FORMAT=decimal

# [PUBLIC] UI refresh interval in milliseconds
NEXT_PUBLIC_REFRESH_INTERVAL=30000

# [PUBLIC] Animation duration in milliseconds
NEXT_PUBLIC_ANIMATION_DURATION=300

# [PUBLIC] Notification timeout in milliseconds
NEXT_PUBLIC_NOTIFICATION_TIMEOUT=5000

# [PUBLIC] Feature flags (true/false)
NEXT_PUBLIC_ENABLE_CASHOUT=true
NEXT_PUBLIC_ENABLE_INPLAY=true
NEXT_PUBLIC_ENABLE_MULTI_MARKET=true
NEXT_PUBLIC_ENABLE_ADVANCED_CHARTS=true
NEXT_PUBLIC_ENABLE_SOCIAL_TRADING=false

# ==================== MONITORING & LOGGING ====================
# [INTERNAL] Log level (error, warn, info, debug, trace)
LOG_LEVEL=info

# [SECRET] Sentry DSN for error tracking (optional)
SENTRY_DSN=

# ==================== RATE LIMITING ====================
# [INTERNAL] Rate limit window in milliseconds
RATE_LIMIT_WINDOW_MS=60000

# [INTERNAL] Maximum requests per window
RATE_LIMIT_MAX_REQUESTS=100

# ==================== CORS CONFIGURATION ====================
# [PUBLIC] CORS allowed origins (comma-separated)
CORS_ORIGINS=http://localhost:3000

# ==================== DEPRECATED (for backward compatibility) ====================
# [SECRET] Legacy odds API key
ODDS_API_KEY=

# ==================== RAILWAY DEPLOYMENT NOTES ====================
# For Railway deployment:
# 1. Set PORT (Railway automatically provides PORT environment variable)
# 2. Set MONGODB_URI to Railway MongoDB service URL
# 3. Set REDIS_URL to Railway Redis service URL
# 4. Set JWT_SECRET to a secure random string
# 5. For frontend, set NEXT_PUBLIC_API_URL to your Railway API service URL
#    Example: https://api-production-1234.up.railway.app
# 6. For production, set NODE_ENV=production
# 7. Railway automatically injects RAILWAY_STATIC_URL for web service
#    and RAILWAY_PUBLIC_DOMAIN for API service
